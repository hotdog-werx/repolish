[project]
name = "{{ repo_name }}"
description = "Repolish provider"
authors = [{ name = "" }]
readme = "README.md"
license = "MIT"
requires-python = ">=3.11"
dynamic = ["version"]

dependencies = [
  "repolish",
  "typing_extensions>=4.0; python_version < '3.12'",
]

[project.scripts]
{{ repo_name }}-link = "{{ package_name }}.repolish.linker:main"

[tool.hatch]
build.packages = ["{{ package_name }}"]
build.include = ["{{ package_name }}/resources/**"]
version.path = "{{ package_name }}/version.py"
metadata.allow-direct-references = true

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
